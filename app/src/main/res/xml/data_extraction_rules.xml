<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules — Android 12+
    Stessa logica di backup_rules.xml ma per la nuova API.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="savio_db" />
        <exclude domain="database" path="savio_db-shm" />
        <exclude domain="database" path="savio_db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="savio_db" />
    </device-transfer>
</data-extraction-rules>
